---
import {
	getEmDashEntry,
	getEmDashCollection,
	getTermsForEntries,
	getSeoMeta,
	getSiteSetting,
	decodeSlug,
} from "emdash";
import { resolveActiveTemplate } from "../../template";

const slug = decodeSlug(Astro.params.slug);
if (!slug) return Astro.redirect("/404");

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);
if (!post) return Astro.redirect("/404");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http") ? image.src : `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const key =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (key) return `${Astro.url.origin}/_emdash/api/media/file/${key}`;
	return undefined;
}

const siteTitle = (await getSiteSetting("title")) ?? "Site";
const seo = getSeoMeta(post, {
	siteTitle: String(siteTitle),
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: getImageUrl(post.data.featured_image),
});

const bylines = post.data.bylines ?? [];
const tags = post.data.terms?.tag ?? [];

const { entries: recent } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const others = recent.filter((p) => p.id !== post.id).slice(0, 3);
const otherTags = await getTermsForEntries("posts", others.map((p) => p.data.id), "tag");
const otherPosts = others.map((p) => ({
	post: p,
	tags: otherTags.get(p.data.id) ?? [],
	bylines: p.data.bylines ?? [],
}));

const { Layout, Post } = await resolveActiveTemplate(Astro);
---

<Layout
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<Post post={post} bylines={bylines} tags={tags} otherPosts={otherPosts} />
</Layout>
