---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}
const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
} = Astro.props;

const settings = await getSiteSettings();
const siteTitle = settings?.title ?? "Site";
const siteTagline = settings?.tagline ?? "";
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;
const menu = await getMenu("primary");
const isLoggedIn = !!Astro.locals.user;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});
---

<!doctype html>
<html lang="en" data-template="minimal">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class="m-header">
			<div class="m-header-inner">
				<a href="/" class="m-brand">{siteTitle}</a>
				<nav class="m-nav">
					{menu?.items.map((item) => (
						<a href={item.url} target={item.target}>{item.label}</a>
					))}
					<a href="/search">Search</a>
					{isLoggedIn && <a href="/_emdash/admin" class="m-admin">Admin</a>}
				</nav>
			</div>
		</header>

		<main class="m-main"><slot /></main>

		<footer class="m-footer">
			<div class="m-footer-inner">
				<p>{siteTitle}{siteTagline ? ` — ${siteTagline}` : ""}</p>
				<p class="m-muted"><a href="/rss.xml">RSS</a> · Powered by <a href="https://emdashcms.com">EmDash</a></p>
			</div>
		</footer>
		<EmDashBodyEnd page={pageCtx} />

		<style is:global>
			:root {
				--m-bg: #ffffff; --m-text: #1a1a1a; --m-muted: #6b7280; --m-border: #e5e7eb;
				--m-accent: #111827;
				--m-serif: Georgia, "Iowan Old Style", "Times New Roman", serif;
				--m-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
				--m-measure: 680px;
			}
			@media (prefers-color-scheme: dark) {
				:root { --m-bg: #0f1115; --m-text: #e8eaed; --m-muted: #9aa0a6; --m-border: #262a30; --m-accent: #f3f4f6; }
			}
			* { box-sizing: border-box; }
			body, h1, h2, h3, h4, p, ul, ol, figure, blockquote { margin: 0; }
			html { scroll-behavior: smooth; }
			body { font-family: var(--m-sans); background: var(--m-bg); color: var(--m-text); line-height: 1.65; -webkit-font-smoothing: antialiased; min-height: 100vh; }
			h1, h2, h3, h4 { font-family: var(--m-serif); line-height: 1.2; font-weight: 700; }
			a { color: inherit; }
			img { max-width: 100%; height: auto; display: block; }
		</style>
		<style>
			.m-header { border-bottom: 1px solid var(--m-border); position: sticky; top: 0; background: color-mix(in srgb, var(--m-bg) 88%, transparent); backdrop-filter: blur(8px); z-index: 50; }
			.m-header-inner { max-width: 820px; margin: 0 auto; padding: 1.1rem 1.5rem; display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
			.m-brand { font-family: var(--m-serif); font-size: 1.35rem; font-weight: 700; text-decoration: none; letter-spacing: -0.01em; }
			.m-nav { display: flex; gap: 1.25rem; font-size: 0.95rem; }
			.m-nav a { text-decoration: none; color: var(--m-muted); transition: color 0.15s ease; }
			.m-nav a:hover { color: var(--m-text); }
			.m-admin { color: var(--m-text) !important; }
			.m-main { min-height: 60vh; }
			.m-footer { border-top: 1px solid var(--m-border); margin-top: 4rem; }
			.m-footer-inner { max-width: 820px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; font-size: 0.9rem; color: var(--m-muted); }
			.m-footer a { color: var(--m-muted); }
			.m-footer a:hover { color: var(--m-text); }
			.m-muted { color: var(--m-muted); }
			@media (max-width: 560px) { .m-header-inner { flex-direction: column; align-items: flex-start; gap: 0.5rem; } }
		</style>
	</body>
</html>
